# Ticketmaster One credentials
TM_EMAIL=
TM_PASSWORD=
TM1_BASE_URL=https://one.ticketmaster.com
TM1_API_PREFIX=/api/prd119/api/caui
TM1_EVENTBASE_API_PREFIX=/api/events
TM1_TCODE=
TM1_COOKIE=
TM1_XSRF_TOKEN=
TM1_DEFAULT_EVENT_START=2026-02-01
TM1_DEFAULT_EVENT_END=2029-12-31
TM1_TIMEOUT_MS=20000

# Where the live app is running (use localhost:3000 for local dev)
INGEST_URL=https://your-app.vercel.app/api/ingest
INGEST_SECRET=

# Supabase (for job queue - enables Run buttons in the web dashboard)
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Path to your local claude CLI (default is the standard install location)
# Find yours with: which claude
CLAUDE_PATH=/Users/yourname/.local/bin/claude

# How often to check TM One automatically (cron format, default: every 2 hours)
# TM1 scheduler is off by default to avoid noisy auth/runtime alerts. Manual TM checks still work.
SCHEDULED_OWNER_NOTIFICATIONS=false
TM_SCHEDULER_ENABLED=false
EATA_SCHEDULER_ENABLED=false
CHECK_CRON=0 */2 * * *

# Discord bot
# Get token from Discord Developer Portal > Your App > Bot > Reset Token
DISCORD_TOKEN=
# Right-click a channel in Discord > Copy Channel ID (enable Developer Mode first)
DISCORD_CHANNEL_ID=

# Discord server management (required for admin features)
# Application ID from Discord Developer Portal > Your App > General Information
DISCORD_CLIENT_ID=
# Right-click server name > Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID=
# Channel where the bot posts moderation logs and reports
DISCORD_LOG_CHANNEL_ID=
# Channel where new member welcome messages are posted
DISCORD_WELCOME_CHANNEL_ID=
# Comma-separated owner Discord user IDs (owner-only channels + commands)
DISCORD_OWNER_USER_IDS=
WHATSAPP_OWNER_NUMBERS=
# Optional custom role names if you don't want the defaults
DISCORD_OWNER_ROLE_NAME=Owner
DISCORD_ADMIN_ROLE_NAME=Admin
DISCORD_TEAM_ROLE_NAME=Team
DISCORD_VIEWER_ROLE_NAME=Viewer
DISCORD_BOT_ROLE_NAME=Bot
DISCORD_RESTRUCTURE_PRUNE=false
GMAIL_PUBSUB_TOPIC=
GMAIL_PUSH_LABEL_IDS=INBOX,SENT
GMAIL_IMPERSONATE_USER=jaime@outletmedia.net
EMAIL_HISTORY_POLL_CRON=*/1 8-22 * * *
# WhatsApp Cloud API webhook verification / future outbound support
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_APP_SECRET=
# Role ID auto-assigned to new members (optional)
DISCORD_DEFAULT_ROLE_ID=
# Comma-separated channel IDs exempt from auto-moderation (e.g. admin channels)
DISCORD_EXEMPT_CHANNELS=
# Comma-separated words that get auto-deleted (optional)
DISCORD_BANNED_WORDS=

# Optional legacy mirror for old email summary behavior.
EMAIL_NOTIFY_DISCORD=false
