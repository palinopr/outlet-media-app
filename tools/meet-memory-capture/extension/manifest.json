{
  "manifest_version": 3,
  "name": "Outlet Meet Memory Capture",
  "version": "0.1.0",
  "description": "Capture visible Google Meet captions and send reviewed notes to Outlet Media Memory.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://127.0.0.1:7766/*",
    "http://localhost:7766/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Outlet Meet Memory"
  }
}
