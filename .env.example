# Clerk Auth (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin/dashboard

# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Never expose this client-side

# Ingest secret - shared between this app and scraper/.env
# Generate: openssl rand -hex 32
INGEST_SECRET=change-this-to-a-random-string

# Meta Marketing API (optional - add when ready)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Meta OAuth (required for client self-serve ad management)
META_APP_ID=
META_APP_SECRET=
# Generate: openssl rand -hex 32 (min 32 chars)
TOKEN_ENCRYPTION_KEY=

# WhatsApp Cloud API (optional - required for customer WhatsApp intake)
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0

# Evolution API (preferred for the current phone-linked WhatsApp lane)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_WEBHOOK_SECRET=

# Twilio WhatsApp (legacy / optional fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=true
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_STATUS_CALLBACK_URL=
TWILIO_WHATSAPP_TYPING_INDICATOR=false
WHATSAPP_AUTO_ACK_DELAY_MS=1500
WHATSAPP_AUTO_ACK_TEXT=Got it. Working on it now.
WHATSAPP_AUTO_ACK_COOLDOWN_SECONDS=45
WHATSAPP_APPROVED_CONVERSATION_MODE=live

# Ticketmaster API (get from https://developer.ticketmaster.com)
TICKETMASTER_API_KEY=

# TM1 browserless internal API access
# Capture these from a working TM1 session once, then let the app call TM1 directly.
TM1_BASE_URL=https://one.ticketmaster.com
TM1_API_PREFIX=/api/prd119/api/caui
TM1_EVENTBASE_API_PREFIX=/api/events
TM1_TCODE=
TM1_COOKIE=
TM1_XSRF_TOKEN=
TM1_DEFAULT_EVENT_START=2026-02-01
TM1_DEFAULT_EVENT_END=2029-12-31
TM1_TIMEOUT_MS=20000

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://outlet-media-app-production.up.railway.app

# Discord (agent bot)
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxx
