# Clerk Auth (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin/dashboard

# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Never expose this client-side

# Ingest secret for authenticated Meta data ingestion
# Generate: openssl rand -hex 32
INGEST_SECRET=change-this-to-a-random-string

# Meta Marketing API (optional - add when ready)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Meta signed-request verification / legacy callback support
META_APP_SECRET=

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://outlet-media-app-production.up.railway.app

# Observability
APPLICATION_ERROR_ALERT_WINDOW_MINUTES=60

# Authenticated Playwright smoke tests (optional; use a Clerk secret for the target environment)
E2E_BASE_URL=https://outletmedia.net
E2E_CLERK_SECRET_KEY=sk_test_or_sk_live_for_target_environment
E2E_CLIENT_SLUG=sienna
E2E_CLIENT_SLUGS=sienna,zamora,kybba,distill_pr,vaz_vil_enterprise,chris_r,proteccion_final,beamina,happy_paws,don_omar_bcn
E2E_CLIENT_MEMBER_SLUGS=sienna,zamora
# Optional: enables temporary non-admin client-member acceptance without real client invites.
E2E_SUPABASE_URL=https://xxxx.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (optional contact-form email delivery)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL="Outlet Media <noreply@outletmedia.co>"
CONTACT_FORM_TO_EMAIL=info@outletmedia.net
