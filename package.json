{
  "name": "outlet-media-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:web",
    "lint:web": "eslint src __tests__ vitest.config.ts vitest.setup.ts",
    "type-check": "npm run type-check:web",
    "type-check:web": "tsc --noEmit",
    "test": "npm run test:web",
    "test:web": "vitest run",
    "audit:deps": "npm audit --audit-level=moderate",
    "audit:data": "node --env-file=.env.local scripts/audit-data.mjs",
    "audit:surfaces": "node scripts/audit-surfaces.mjs",
    "backfill:ticketmaster-attribution": "node --env-file=.env.local scripts/backfill-ticketmaster-attribution.mjs",
    "db:push:dry-run": "supabase db push --dry-run",
    "refresh:snapshots": "node --env-file=.env.local scripts/refresh-snapshots.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "check:web": "npm run type-check:web && npm run lint:web && npm run test:web && npm run build && npm run audit:deps",
    "check": "npm run check:web",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.5",
    "@supabase/supabase-js": "^2.96.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.574.0",
    "next": "^16.2.4",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
